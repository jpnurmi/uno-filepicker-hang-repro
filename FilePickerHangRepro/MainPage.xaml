<Page x:Class="FilePickerHangRepro.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:FilePickerHangRepro"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
  <Grid>
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
      <Button x:Name="PickButton" Content="Pick files..." Click="OnPickClicked" />
      <TextBlock x:Name="StatusText" Text="Idle" HorizontalAlignment="Center" />
    </StackPanel>
  </Grid>
</Page>
